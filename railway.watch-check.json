{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "dockerfiles/cron.Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'curl --fail-with-body -sSi -X POST -H \"Authorization: Bearer $INGEST_SECRET\" \"$WEB_BASE_URL/api/cron/watch-check\"'",
    "cronSchedule": "0 16 * * *",
    "restartPolicyType": "NEVER"
  }
}
