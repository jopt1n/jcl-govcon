{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo \"Skipping Next.js build for weekly crawl worker\""
  },
  "deploy": {
    "startCommand": "npm run cron:weekly-crawl",
    "cronSchedule": "0 15 * * 5",
    "restartPolicyType": "NEVER"
  }
}
