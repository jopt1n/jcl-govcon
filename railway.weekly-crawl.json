{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "dockerfiles/cron.Dockerfile"
  },
  "deploy": {
    "startCommand": "curl --fail-with-body -sSi -X POST -H \"Authorization: Bearer $INGEST_SECRET\" \"$WEB_BASE_URL/api/cron/weekly-crawl\"",
    "cronSchedule": "0 15 * * 1",
    "restartPolicyType": "NEVER"
  }
}
